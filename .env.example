# Proposal password gate (both required for login to be enforced)
# Copy to .env.local and fill in — never commit .env.local
PROPOSAL_USER=your_username
PROPOSAL_PASS=your_secure_password

# Optional: use a long random string (≥16 chars) so session cookies are signed with a
# dedicated secret instead of a key derived from username + password.
# PROPOSAL_SESSION_SECRET=
